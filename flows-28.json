    {
        "id": "3ff16bd7c1d6d39e",
        "type": "function",
        "z": "cba0e6d3d33da297",
        "name": "format lines",
        "func": "let line1, line2;\n\nlet soil  = global.get(\"soil_pct\")        ?? \"--\";\nlet tank  = global.get(\"water_level_pct\") ?? \"--\";\nlet spill = global.get(\"spill_detected\");\nlet pump  = global.get(\"pump_running\");\nlet low   = global.get(\"low_water\");\n\nif (spill) {\n    line1 = \"SPILL DETECTED!\";\n    line2 = \"Pump OFF\";\n} else if (low) {\n    line1 = \"Refill Tank!\";\n    line2 = \"Tank: \" + tank + \"%\";\n} else if (pump) {\n    line1 = \"Watering...\";\n    line2 = \"Tank: \" + tank + \"%\";\n} else {\n    line1 = \"Soil: \" + soil + \"%\";\n    line2 = \"Tank: \" + tank + \"%\";\n}\n\nmsg.payload = '\"' + line1 + '\" \"' + line2 + '\"';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 540,
        "wires": [
            [
                "d632ea19cf972b52",
                "fe86ab25b3ed0da9"
            ]
        ]
    },
