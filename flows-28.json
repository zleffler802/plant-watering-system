    {
        "id": "f5fd84a34858938b",
        "type": "function",
        "z": "4cd008773e23b584",
        "name": "Convert & Store Water Level %",
        "func": "// Convert distance to water level %, store globals.\n// Calibration: 3.0cm = 100% (full), 9.0cm = 0% (empty/2L mark).\nconst dist = parseFloat(msg.payload);\nconst pct = Math.max(0, Math.min(100, Math.round(((9 - dist) / 6) * 100)));\n\nglobal.set('water_level_pct', pct);\nglobal.set('low_water', pct < 10);\nmsg.payload = pct;\n\nif (pct < 10) {\n    return [msg, null];  // out1: low warning\n} else {\n    return [null, msg];  // out2: ok\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1030,
        "y": 340,
        "wires": [
            [
                "cd136d632a1e4c18",
                "5e36fcd90ee7dd62",
                "e8f4b74ce0173564"
            ],
            [
                "cd136d632a1e4c18",
                "5e36fcd90ee7dd62",
                "6cdaa3b9ecd974ec"
            ]
        ]
    },
    {
        "id": "safety_gate",
        "type": "function",
        "z": "4cd008773e23b584",
        "name": "Safety Gate - OK to Water?",
        "func": "// Safety check \u2014 reads all values from global context.\n// Block watering if any condition fails.\nconst soil     = global.get('soil_pct');\nconst spill    = global.get('spill_detected');\nconst lowWater = global.get('low_water');\n\nif (soil     === undefined) return null;\nif (spill    !== false)     return null;\nif (lowWater !== false)     return null;\nif (soil     >= 40)         return null;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 600,
        "y": 500,
        "wires": [
            [
                "pump_cycle"
            ]
        ]
    },
    {
        "id": "pump_cycle",
        "type": "function",
        "z": "4cd008773e23b584",
        "name": "Pump ON 3s then OFF",
        "func": "// Guard against re-entry if already running\nif (global.get('pump_running') === true) return null;\n\nglobal.set('pump_running', true);\nnode.send([{ payload: 1 }, { payload: 'on' }]);\n\nsetTimeout(function () {\n    global.set('pump_running', false);\n    node.send([\n        { payload: 0 },\n        { payload: 'off' },\n        { payload: new Date().toLocaleString() },\n        null\n    ]);\n    // After 2s settling delay, trigger a fresh distance read\n    setTimeout(function () {\n        node.send([null, null, null, { payload: 'poll' }]);\n    }, 2000);\n}, 3000);\n\nreturn null;",
        "outputs": 4,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "flow.set('pump_running', false);",
        "libs": [],
        "x": 1080,
        "y": 560,
        "wires": [
            [
                "c6540b4bb1190b99",
                "ae3239246d440954",
                "ce6da2703e9afd34"
            ],
            [
                "92a0f52bedc23225"
            ],
            [
                "lnk_out_last_watered"
            ],
            [
                "2a68f2a723365e41"
            ]
        ]
    },
    {
        "id": "manual_override",
        "type": "function",
        "z": "4cd008773e23b584",
        "name": "Manual Override",
        "func": "if (msg.payload !== 1) return null;\n\nconst spill    = global.get('spill_detected');\nconst lowWater = global.get('low_water');\n\nif (spill    !== false) return null;\nif (lowWater !== false) return null;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 720,
        "y": 720,
        "wires": [
            [
                "pump_cycle"
            ]
        ]
    },
